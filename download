<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>KG Bidding — Admin</title>
<style>
:root{--navy:#1e3a5f;--accent:#2f6fed;--accent-d:#1f56c4;--bg:#f4f6fa;--line:#e3e8f0;--txt:#1b2437;--mut:#6b7690;--green:#188a52;--red:#d13438;--amber:#b7791f}
*{box-sizing:border-box;margin:0;padding:0}
body{font:14px/1.45 'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--txt)}
button{font:inherit;cursor:pointer;border:none;border-radius:8px}
input,select,textarea{font:inherit;border:1px solid var(--line);border-radius:8px;padding:9px 11px;outline:none;background:#fff;width:100%}
input:focus,textarea:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(47,111,237,.12)}
.hidden{display:none!important}
.btn-main{background:var(--accent);color:#fff;padding:10px 18px;font-weight:600}
.btn-main:hover{background:var(--accent-d)} .btn-main:disabled{opacity:.5}
.btn-ghost{background:#fff;border:1px solid var(--line);padding:8px 14px;font-weight:600}
.btn-ghost:hover{border-color:var(--accent);color:var(--accent)}
.btn-danger{background:#fdecea;color:var(--red);border:1px solid #f5c6c4;padding:8px 14px;font-weight:600}
.btn-green{background:var(--green);color:#fff;padding:8px 14px;font-weight:600}
.err{color:var(--red);font-size:13px;min-height:18px;margin-top:8px}

#loginView{min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#152a46,#1e3a5f)}
.login-card{background:#fff;border-radius:16px;padding:36px;width:360px;max-width:92vw;box-shadow:0 24px 60px rgba(0,0,0,.35)}
.login-card h1{font-size:19px;color:var(--navy);margin-bottom:4px}
.login-card p{color:var(--mut);font-size:13px;margin-bottom:20px}
.login-card .btn-main{width:100%;margin-top:16px}

header.app{position:sticky;top:0;z-index:40;background:var(--navy);color:#fff;display:flex;align-items:center;gap:14px;padding:0 22px;height:56px}
header.app .logo{font-weight:700;letter-spacing:.5px}
header.app .tag{background:rgba(255,255,255,.15);font-size:11px;padding:3px 10px;border-radius:12px}
header.app .sp{flex:1}
.wrap{max-width:1200px;margin:0 auto;padding:24px 20px 80px}
.card{background:#fff;border:1px solid var(--line);border-radius:12px;padding:22px;margin-bottom:20px;box-shadow:0 1px 4px rgba(20,40,80,.05)}
.card h2{font-size:16px;color:var(--navy);margin-bottom:14px}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
label{display:block;font-size:12px;font-weight:600;color:var(--mut);margin-bottom:5px;text-transform:uppercase;letter-spacing:.4px}
.field{margin-bottom:14px}
table{border-collapse:collapse;width:100%}
th{background:#f8fafd;color:#51607d;font-size:11.5px;text-transform:uppercase;letter-spacing:.4px;padding:10px;text-align:left;border-bottom:1px solid var(--line);white-space:nowrap}
td{padding:10px;border-bottom:1px solid #eef1f7;font-variant-numeric:tabular-nums}
tr:hover td{background:#f6f9ff}
.status-live{background:#e7f6ee;color:var(--green);padding:3px 10px;border-radius:12px;font-size:12px;font-weight:700}
.status-closed{background:#fdecea;color:var(--red);padding:3px 10px;border-radius:12px;font-size:12px;font-weight:700}
.mut{color:var(--mut);font-size:12.5px}
.clientrow{cursor:pointer}
.toast{position:fixed;top:70px;right:20px;background:var(--green);color:#fff;padding:12px 20px;border-radius:10px;z-index:80;font-weight:600;box-shadow:0 8px 26px rgba(0,0,0,.3)}
.toast.bad{background:var(--red)}
.overlay{position:fixed;inset:0;background:rgba(15,25,45,.55);z-index:60;display:flex;align-items:center;justify-content:center;padding:18px}
.modal{background:#fff;border-radius:14px;max-width:1000px;width:100%;max-height:90vh;display:flex;flex-direction:column}
.modal-h{display:flex;justify-content:space-between;align-items:center;padding:16px 22px;border-bottom:1px solid var(--line)}
.modal-h h2{font-size:16px;color:var(--navy)}
.modal-x{background:none;font-size:22px;color:var(--mut)}
.modal-b{padding:16px 22px;overflow:auto}
.linkbox{display:flex;gap:8px;align-items:center;background:#f8fafd;border:1px dashed var(--line);border-radius:8px;padding:10px 12px;margin-top:10px}
.linkbox code{flex:1;font-size:13px;color:var(--navy);overflow:auto;white-space:nowrap}
.empty{padding:40px;text-align:center;color:var(--mut)}
</style>
</head>
<body>

<div id="loginView">
  <div class="login-card">
    <h1>KG Bidding — Admin</h1>
    <p>Enter the admin password to manage bidding events.</p>
    <label>Admin Password</label>
    <input type="password" id="pw" onkeydown="if(event.key==='Enter')doLogin()">
    <div class="err" id="loginErr"></div>
    <button class="btn-main" onclick="doLogin()">Sign In</button>
  </div>
</div>

<div id="appView" class="hidden">
  <header class="app">
    <div class="logo">K GIRDHARLAL &amp; CO.</div><div class="tag">ADMIN</div>
    <div class="sp"></div>
    <button class="btn-ghost" style="background:transparent;color:#cfe0f5;border-color:rgba(255,255,255,.3)" onclick="logout()">Logout</button>
  </header>
  <div class="wrap">

    <div class="card">
      <h2>Create New Bidding Event</h2>
      <div class="grid2">
        <div class="field"><label>Event Name</label><input id="evName" placeholder="e.g. July Tender — Round 3ct+"></div>
        <div class="field"><label>Bidding Ends At (your local time)</label><input type="datetime-local" id="evEnd"></div>
      </div>
      <div class="field"><label>Terms shown to bidders (optional)</label><input id="evTerms" placeholder="e.g. Local Bill ($) – With Cert. No. Details – (0-6 Days)"></div>
      <div class="field"><label>Stocklist Excel (.xlsx)</label><input type="file" id="evFile" accept=".xlsx,.xls"></div>
      <div class="mut">Uploading a new stocklist starts a fresh event and closes any currently live event. Required columns: STONE ID and CTS — everything else (color, clarity, rap, disc, links…) is picked up automatically. Hyperlinks on STONE ID and REPORT NO. are captured for the stone page / certificate.</div>
      <div class="err" id="createErr"></div>
      <button class="btn-main" id="createBtn" onclick="createEvent()" style="margin-top:6px">Upload &amp; Go Live</button>
      <div class="linkbox"><span class="mut">Share with clients:</span><code id="shareLink"></code><button class="btn-ghost" onclick="copyLink()">Copy</button></div>
    </div>

    <div class="card">
      <h2>Events</h2>
      <div id="eventsBox"></div>
    </div>

    <div class="card">
      <h2 id="sumTitle">Bids by Company</h2>
      <div id="summaryBox"><div class="empty">Select an event above to see its bids.</div></div>
    </div>

    <div class="card">
      <h2>All Registered Clients</h2>
      <div id="clientsBox"></div>
    </div>

  </div>
</div>

<!-- client bids modal -->
<div class="overlay hidden" id="cbOverlay">
  <div class="modal">
    <div class="modal-h"><h2 id="cbTitle">Bids</h2><button class="modal-x" onclick="$('cbOverlay').classList.add('hidden')">×</button></div>
    <div class="modal-b" id="cbBody"></div>
  </div>
</div>

<script>
const $=id=>document.getElementById(id);
const fmt=(n,d=2)=>n==null?'-':Number(n).toLocaleString('en-US',{minimumFractionDigits:d,maximumFractionDigits:d});
const fmt0=n=>n==null?'-':Number(n).toLocaleString('en-US',{maximumFractionDigits:0});
const esc=s=>String(s??'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
const dt=ms=>ms?new Date(ms).toLocaleString():'-';
let CUR_EVENT=null;

async function api(url,opts={}){
  const r=await fetch(url,opts.body instanceof FormData?opts:{headers:{'Content-Type':'application/json'},...opts});
  const j=await r.json().catch(()=>({}));
  if(!r.ok)throw new Error(j.error||'Request failed');
  return j;
}
function toast(msg,cls=''){const t=document.createElement('div');t.className='toast '+cls;t.textContent=msg;document.body.appendChild(t);setTimeout(()=>t.remove(),2800)}

async function doLogin(){
  $('loginErr').textContent='';
  try{
    await api('/api/admin/login',{method:'POST',body:JSON.stringify({password:$('pw').value})});
    enterApp();
  }catch(e){$('loginErr').textContent=e.message}
}
async function logout(){await api('/api/logout',{method:'POST'});location.reload()}

function enterApp(){
  $('loginView').classList.add('hidden');$('appView').classList.remove('hidden');
  $('shareLink').textContent=location.origin+'/';
  loadEvents();loadClients();
}
function copyLink(){navigator.clipboard.writeText(location.origin+'/').then(()=>toast('Link copied'))}

async function createEvent(){
  $('createErr').textContent='';
  const f=$('evFile').files[0],name=$('evName').value.trim(),end=$('evEnd').value;
  if(!name||!end||!f){$('createErr').textContent='Event name, end time and Excel file are all required.';return}
  const endMs=new Date(end).getTime();
  const fd=new FormData();
  fd.append('name',name);fd.append('terms',$('evTerms').value);fd.append('end_time',endMs);fd.append('file',f);
  $('createBtn').disabled=true;
  try{
    const j=await api('/api/admin/events',{method:'POST',body:fd});
    toast(`Event live with ${j.stones} stones ✓`);
    $('evFile').value='';loadEvents();
  }catch(e){$('createErr').textContent=e.message}
  $('createBtn').disabled=false;
}

async function loadEvents(){
  const j=await api('/api/admin/events');
  if(!j.events.length){$('eventsBox').innerHTML='<div class="empty">No events yet — create one above.</div>';return}
  $('eventsBox').innerHTML=`<div style="overflow:auto"><table><thead><tr>
    <th>Event</th><th>Status</th><th>Ends</th><th>Stones</th><th>Bidders</th><th>Bids</th><th></th></tr></thead><tbody>`+
    j.events.map(e=>{
      const live=e.status==='live'&&j.server_time<e.end_time;
      return `<tr>
      <td><b>${esc(e.name)}</b><div class="mut">${esc(e.terms||'')}</div></td>
      <td><span class="${live?'status-live':'status-closed'}">${live?'LIVE':(e.status==='live'?'ENDED':'CLOSED')}</span></td>
      <td>${dt(e.end_time)}</td><td>${e.stone_count}</td><td>${e.bidder_count}</td><td>${e.bid_count}</td>
      <td style="white-space:nowrap">
        <button class="btn-ghost" onclick="loadSummary(${e.id},'${esc(e.name)}')">View Bids</button>
        <button class="btn-green" onclick="exportExcel(${e.id})">⬇ Excel</button>
        ${e.status==='live'?`<button class="btn-danger" onclick="setStatus(${e.id},'closed')">Close</button>`
                           :`<button class="btn-ghost" onclick="setStatus(${e.id},'live')">Re-open</button>`}
      </td></tr>`}).join('')+'</tbody></table></div>';
  // auto-select latest event for summary
  if(!CUR_EVENT&&j.events.length)loadSummary(j.events[0].id,j.events[0].name);
}
async function setStatus(id,status){
  if(status==='closed'&&!confirm('Close bidding for this event?'))return;
  await api('/api/admin/events/'+id,{method:'PATCH',body:JSON.stringify({status})});
  loadEvents();toast(status==='closed'?'Event closed':'Event re-opened');
}
function exportExcel(id){location.href='/api/admin/events/'+id+'/export'}

async function loadSummary(id,name){
  CUR_EVENT=id;
  $('sumTitle').textContent=`Bids by Company — ${name}`;
  const j=await api(`/api/admin/events/${id}/summary`);
  if(!j.clients.length){$('summaryBox').innerHTML='<div class="empty">No bids yet for this event.</div>';return}
  $('summaryBox').innerHTML=`<div style="overflow:auto"><table><thead><tr>
    <th>Company</th><th>Name</th><th>Contact</th><th>Stones Bid</th><th>Total Amount $</th><th>Last Activity</th><th></th></tr></thead><tbody>`+
    j.clients.map(c=>`<tr class="clientrow" onclick="openClientBids(${id},${c.id})">
      <td><b>${esc(c.company)}</b></td><td>${esc(c.name)}</td><td>${esc(c.contact)}</td>
      <td>${c.bid_count}</td><td><b>${fmt0(c.total_amount)}</b></td><td>${dt(c.last_bid_at)}</td>
      <td><button class="btn-ghost">View Detail →</button></td></tr>`).join('')+'</tbody></table></div>';
}

async function openClientBids(evId,clientId){
  const j=await api(`/api/admin/events/${evId}/clients/${clientId}/bids`);
  $('cbTitle').textContent=`${j.client.company} — ${j.client.name} (${j.client.contact})`;
  const total=j.bids.reduce((a,b)=>a+b.bid_amount,0);
  $('cbBody').innerHTML=`<div style="overflow:auto"><table><thead><tr>
    <th>Stone ID</th><th>Shape</th><th>Cts</th><th>Col</th><th>Cla</th><th>C·P·S</th><th>Fluor</th><th>Rap</th>
    <th>Ask Disc%</th><th>Ask $/Ct</th><th>Bid Disc%</th><th>Bid $/Ct</th><th>Bid Amt $</th><th>Updated</th></tr></thead><tbody>`+
    j.bids.map(b=>`<tr>
      <td><b>${esc(b.stone_id)}</b></td><td>${esc(b.shape)}</td><td>${fmt(b.cts)}</td><td>${esc(b.color)}</td><td>${esc(b.clarity)}</td>
      <td>${[b.cut,b.pol,b.symm].filter(Boolean).join('·')}</td><td>${esc(b.fluor||'-')}</td><td>${fmt0(b.rap)}</td>
      <td>${b.ask_disc==null?'-':fmt(b.ask_disc)+'%'}</td><td>${fmt0(b.ask_per_ct)}</td>
      <td style="color:var(--green);font-weight:700">${b.bid_disc==null?'-':fmt(b.bid_disc)+'%'}</td>
      <td style="color:var(--green);font-weight:700">${fmt0(b.bid_per_ct)}</td>
      <td><b>${fmt(b.bid_amount)}</b></td><td class="mut">${dt(b.updated_at)}</td></tr>`).join('')+
    `<tr><td colspan="12" style="text-align:right"><b>TOTAL</b></td><td><b>${fmt(total)}</b></td><td></td></tr>`+
    '</tbody></table></div>';
  $('cbOverlay').classList.remove('hidden');
}

async function loadClients(){
  const j=await api('/api/admin/clients');
  if(!j.clients.length){$('clientsBox').innerHTML='<div class="empty">No clients registered yet.</div>';return}
  $('clientsBox').innerHTML=`<div style="overflow:auto"><table><thead><tr>
    <th>Company</th><th>Name</th><th>Email / Mobile</th><th>Registered</th><th>Total Bids (all events)</th></tr></thead><tbody>`+
    j.clients.map(c=>`<tr><td><b>${esc(c.company)}</b></td><td>${esc(c.name)}</td><td>${esc(c.contact)}</td>
      <td>${dt(c.created_at)}</td><td>${c.total_bids}</td></tr>`).join('')+'</tbody></table></div>';
}

// boot: if already admin session
(async()=>{
  try{const j=await api('/api/me');if(j.admin)enterApp()}catch(e){}
})();
</script>
</body>
</html>
